# Path to Google Service Account JSON key file (default: ./service-account.json)
# Create a service account in Google Cloud Console, enable Sheets API,
# share the spreadsheet with the service account email, then download the JSON key
GOOGLE_SERVICE_ACCOUNT_KEY_PATH=./service-account.json

# Sheet ID from the URL: docs.google.com/spreadsheets/d/THIS_PART/edit
GOOGLE_SHEET_ID=1BxiMVs0XRA5nFMdKvBdBZjgmUUqptlbs74OgVE2upms

# Worksheet (tab) name
GOOGLE_SHEET_NAME=Sheet1

# Column range within the worksheet
GOOGLE_SHEET_RANGE=A:BF

# Deposit in USD (fallback for % calculation)
DEPOSIT=100000
